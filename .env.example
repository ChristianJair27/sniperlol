PORT=4000

# Riot Games API key — get one at https://developer.riotgames.com/
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# MySQL (Hostinger or any provider)
MYSQL_HOST=your-mysql-host
MYSQL_USER=your-mysql-user
MYSQL_PASSWORD=your-mysql-password
MYSQL_DB=your-database-name

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGIN=https://your-frontend-domain.com,http://localhost:8080

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-backend-domain.com/auth/google/callback

# Email (tournament invitations) — omit for local dev (uses Ethereal preview URLs in logs)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-smtp-user@your-domain.com
SMTP_PASS=your-smtp-password
SMTP_FROM=ATAK.GG Torneos <your-smtp-user@your-domain.com>

# Frontend / session URLs
WEB_ORIGIN=https://your-frontend-domain.com
CLIENT_URL=https://your-frontend-domain.com
JWT_SECRET=generate-a-long-random-string-here

# Default LoL region (la1 = LAN, na1 = NA, euw1 = EUW…)
DEFAULT_PLATFORM=la1

# LLM / AI (champ-select builds + coaching). Defaults to a local Ollama for dev.
# In PROD point OLLAMA_URL at your hosted Ollama (…/api/chat) or an Ollama-compatible
# endpoint. Keep the host behind auth/private network — never expose it unauthenticated.
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=llama3.1:8b

# Tournament API
# true  → use tournament-stub (test mode, no real lobbies)
# false → use tournament/v5 (production — needs Riot production key)
RIOT_STUB_MODE=false
RIOT_REGION=LAN
TOURNAMENT_CALLBACK_URL=https://your-backend-domain.com/api/tournaments/tournament-callback
# Shared secret appended to the provider callback URL as ?key=… so forged callbacks
# are rejected. Generate a long random string and re-create the provider after setting it.
TOURNAMENT_CALLBACK_SECRET=generate-a-long-random-string-here

# Riot Sign-On (RSO) — OAuth2 "login con Riot"
# RSO_REDIRECT_URI debe coincidir EXACTAMENTE con la registrada en tu producto RSO.
# (RSO no acepta http://localhost — se prueba en HTTPS de producción.)
RSO_CLIENT_ID=your-rso-client-id
RSO_CLIENT_SECRET=your-rso-client-secret
RSO_REDIRECT_URI=https://your-backend-domain.com/auth/riot/callback
RSO_ACCOUNT_REGION=americas
RSO_AUTH_BASE=https://auth.riotgames.com
